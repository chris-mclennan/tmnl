{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo run --example *)",
      "Bash(cargo tree:*)",
      "Bash(./scripts/build-app.sh:*)",
      "Bash(open target/tmnl.app)",
      "Bash(rustc --version)",
      "Bash(cargo --version)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/cargo-fmt-if-rust.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
